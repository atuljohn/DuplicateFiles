<UserControl x:Class="DuplicatePhotoFinder.Views.ScanProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <StackPanel Margin="40" VerticalAlignment="Center" MaxWidth="600" HorizontalAlignment="Center">

            <TextBlock Text="Scanning..." Style="{StaticResource HeadingText}" Margin="0,0,0,24" />

            <!-- Static section: title, progress bar, file counts, timer — these DON'T flicker -->
            <StackPanel>
                <TextBlock Text="{Binding ScanProgress.Phase}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14" Margin="0,0,0,8" />

                <ProgressBar Value="{Binding ScanProgress.ProgressPercent}"
                             Minimum="0" Maximum="100"
                             Height="8" Margin="0,0,0,8">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="{Binding ScanProgress.FilesProcessed, Mode=OneWay}" />
                        <Run Text=" / " />
                        <Run Text="{Binding ScanProgress.TotalFiles, Mode=OneWay}" />
                        <Run Text=" files" />
                    </TextBlock>
                    <TextBlock Grid.Column="1" Foreground="{StaticResource AccentBrush}">
                        <Run Text="{Binding ScanProgress.ProgressPercent, StringFormat='{}{0:F0}%', Mode=OneWay}" />
                    </TextBlock>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                        <Run Text="Elapsed: " />
                        <Run Text="{Binding ScanProgress.ElapsedTime, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock Grid.Column="2" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                        <Run Text="Est. remaining: " />
                        <Run Text="{Binding ScanProgress.EstimatedRemainingTime, Mode=OneWay}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                    </TextBlock>
                </Grid>
            </StackPanel>

            <!-- Volatile section: groups found + current file — these CAN update without reflowing the UI above -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8" Height="50">
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center">
                    <Run Text="Duplicate groups found: " />
                    <Run Text="{Binding ScanProgress.GroupsFound, Mode=OneWay}"
                         Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                </TextBlock>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,16" Height="40">
                <TextBlock Text="{Binding ScanProgress.CurrentFile}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </Border>

            <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelScanCommand}"
                    HorizontalAlignment="Right" />

        </StackPanel>
    </Grid>
</UserControl>
