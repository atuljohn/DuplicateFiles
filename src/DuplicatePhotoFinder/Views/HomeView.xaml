<UserControl x:Class="DuplicatePhotoFinder.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="700">

            <!-- App title -->
            <TextBlock Text="Media Tools"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="36" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="Choose a tool to get started"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="15" HorizontalAlignment="Center"
                       Margin="0,0,0,48" />

            <!-- Feature cards -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Duplicate Finder card -->
                <Button Grid.Column="0"
                        Command="{Binding OpenDuplicateFinderCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="0" Cursor="Hand">
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="12" Padding="32,28">
                        <StackPanel>
                            <TextBlock Text="🔍" FontSize="40"
                                       HorizontalAlignment="Center" Margin="0,0,0,16" />
                            <TextBlock Text="Duplicate Finder"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,10" />
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" LineHeight="20">
                                Scan your media library for exact and visually similar duplicates. Review and safely remove unwanted copies.
                            </TextBlock>
                            <Border Background="{StaticResource AccentBrush}"
                                    CornerRadius="6" Padding="16,8" Margin="0,24,0,0"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="Find Duplicates"
                                           Foreground="White"
                                           FontWeight="SemiBold" FontSize="14" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- File Sync card -->
                <Button Grid.Column="2"
                        Command="{Binding OpenSyncCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="0" Cursor="Hand">
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="12" Padding="32,28">
                        <StackPanel>
                            <TextBlock Text="🔄" FontSize="40"
                                       HorizontalAlignment="Center" Margin="0,0,0,16" />
                            <TextBlock Text="Folder Sync"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,10" />
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" LineHeight="20">
                                Sync files and folders between two locations. Supports one-way copy, mirror, and two-way sync modes.
                            </TextBlock>
                            <Border Background="{StaticResource SuccessBrush}"
                                    CornerRadius="6" Padding="16,8" Margin="0,24,0,0"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="Sync Folders"
                                           Foreground="White"
                                           FontWeight="SemiBold" FontSize="14" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Button>
            </Grid>

        </StackPanel>
    </Grid>
</UserControl>
