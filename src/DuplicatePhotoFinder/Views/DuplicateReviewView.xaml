<UserControl x:Class="DuplicatePhotoFinder.Views.DuplicateReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DuplicatePhotoFinder.Views"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="← Back" Style="{StaticResource SecondaryButton}"
                            Command="{Binding GoBackCommand}" Margin="0,0,12,0" />
                    <TextBlock VerticalAlignment="Center" FontSize="14">
                        <Run Text="{Binding Groups.Count, Mode=OneWay}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                        <Run Text=" duplicate groups found • " Foreground="{StaticResource TextSecondaryBrush}" />
                        <Run Text="{Binding TotalWasteDisplay, Mode=OneWay}" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" />
                        <Run Text=" recoverable" Foreground="{StaticResource TextSecondaryBrush}" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Select All" Style="{StaticResource SecondaryButton}"
                            Command="{Binding SelectAllCommand}" Margin="0,0,8,0" />
                    <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearAllCommand}" Margin="0,0,8,0" />
                    <Button Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteSelectedCommand}"
                            IsEnabled="{Binding IsDeletingFiles, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Delete Selected (" />
                                    <TextBlock Text="{Binding DataContext.SelectedForDeletionCount, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text=" files)" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                        <Button.Content>
                            <x:Null />
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Empty state -->
        <TextBlock Grid.Row="1" Text="No duplicates found!"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Groups.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Groups list (virtualized) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="16,8,16,8">
            <ItemsControl ItemsSource="{Binding Groups}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:DuplicateGroupPanel DataContext="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="16,8">
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                <Run Text="{Binding SelectedForDeletionCount, Mode=OneWay}" />
                <Run Text=" files selected for deletion • " />
                <Run Text="{Binding TotalWasteDisplay, Mode=OneWay}" Foreground="{StaticResource SuccessBrush}" />
                <Run Text=" will be freed • Files are sent to Recycle Bin (not permanently deleted)" />
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
