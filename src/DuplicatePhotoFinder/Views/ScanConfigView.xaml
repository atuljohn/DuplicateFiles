<UserControl x:Class="DuplicatePhotoFinder.Views.ScanConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,40,40,40" MaxWidth="600" HorizontalAlignment="Center">

            <!-- Title -->
            <TextBlock Text="Duplicate Photo &amp; Video Finder"
                       Style="{StaticResource HeadingText}"
                       FontSize="26" Margin="0,0,0,8" />
            <TextBlock Text="Find and remove duplicate photos and videos from your library."
                       Style="{StaticResource SubheadingText}"
                       Margin="0,0,0,32" />

            <!-- Root folder -->
            <TextBlock Text="Root Folder" Foreground="{StaticResource TextPrimaryBrush}"
                       FontWeight="SemiBold" Margin="0,0,0,6" />
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding ScanOptions.RootFolder, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Column="0" Margin="0,0,8,0" />
                <Button Content="Browse" Grid.Column="1"
                        Style="{StaticResource SecondaryButton}"
                        Click="BrowseButton_Click" />
            </Grid>

            <!-- Detection Options -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Detection Options" Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />

                    <CheckBox Content="Exact duplicates (fastest, byte-for-byte identical)"
                              IsChecked="{Binding ScanOptions.DetectExact}"
                              Margin="0,0,0,8" />

                    <CheckBox Content="Similar images (perceptual hash)"
                              IsChecked="{Binding ScanOptions.DetectPerceptual}"
                              Margin="0,0,0,4" />
                    <Grid Margin="20,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sensitivity:" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Slider Grid.Column="1" Minimum="1" Maximum="20"
                                Value="{Binding ScanOptions.PerceptualThreshold}"
                                IsEnabled="{Binding ScanOptions.DetectPerceptual}"
                                TickFrequency="1" IsSnapToTickEnabled="True" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ScanOptions.PerceptualThreshold, StringFormat='Threshold: {0}'}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </Grid>

                    <CheckBox Content="Similar videos (frame sampling, slower)"
                              IsChecked="{Binding ScanOptions.DetectVideo}"
                              Margin="0,0,0,4" />
                    <Grid Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Frames to sample:" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Width="50"
                                 Text="{Binding ScanOptions.VideoFrameCount}"
                                 IsEnabled="{Binding ScanOptions.DetectVideo}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- File Types -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,32">
                <StackPanel>
                    <TextBlock Text="File Types" Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />
                    <TextBlock Text="Images: JPG, PNG, GIF, BMP, TIFF, HEIC, WEBP"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Videos: MP4, MOV, AVI, MKV, WMV, FLV, M4V"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Start button -->
            <Button Content="Start Scan" Style="{StaticResource PrimaryButton}"
                    FontSize="16" Padding="24,12"
                    Command="{Binding StartScanCommand}"
                    HorizontalAlignment="Right" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
