<UserControl x:Class="DuplicatePhotoFinder.Views.DuplicateGroupPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DuplicatePhotoFinder.ViewModels">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="0,0,0,8">
        <Expander IsExpanded="{Binding IsExpanded}">
            <Expander.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="4"
                            Padding="6,2" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MatchKindDisplay}"
                                   Foreground="White" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding Summary}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" FontSize="13" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding WasteBytes, Converter={StaticResource FileSizeConverter}, StringFormat='Save {0}'}"
                               Foreground="{StaticResource SuccessBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" />
                </Grid>
            </Expander.Header>

            <!-- File cards -->
            <ItemsControl ItemsSource="{Binding Files}" Margin="0,8,0,8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MediaFileViewModel}">
                        <Border Width="180" Margin="8,0,0,8" CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1A1A2E" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecommendedKeep}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource KeepBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource DeleteBrush}" />
                                            <Setter Property="Opacity" Value="0.7" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <!-- Thumbnail -->
                                <Grid Height="140" Background="#0D0D1A">
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                           Visibility="{Binding IsLoadingThumbnail, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBlock Text="Loading..."
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding IsLoadingThumbnail, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- Keep badge -->
                                    <Border Background="{StaticResource KeepBrush}" CornerRadius="3"
                                            Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Top"
                                            Margin="4"
                                            Visibility="{Binding IsRecommendedKeep, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="★ KEEP" Foreground="White" FontSize="10" FontWeight="Bold" />
                                    </Border>
                                </Grid>

                                <!-- Metadata -->
                                <StackPanel Margin="8,6,8,4">
                                    <TextBlock Text="{Binding FileName}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FullPath}" />
                                    <TextBlock Text="{Binding FullPath}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="9" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FullPath}" Margin="0,2,0,0" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0">
                                        <Run Text="{Binding ResolutionDisplay, Mode=OneWay}" />
                                        <Run Text=" • " />
                                        <Run Text="{Binding FileSizeDisplay, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding DateDisplay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10" Margin="0,1,0,0" />
                                </StackPanel>

                                <!-- Action buttons -->
                                <Grid Margin="8,0,8,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Keep" Grid.Column="0" Margin="0,0,2,0"
                                            Padding="4,4" FontSize="11"
                                            Command="{Binding DataContext.ToggleKeepCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                <Setter Property="Background" Value="{StaticResource KeepBrush}" />
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Delete" Grid.Column="1" Margin="2,0,0,0"
                                            Padding="4,4" FontSize="11"
                                            Command="{Binding DataContext.ToggleKeepCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="False">
                                                        <Setter Property="Opacity" Value="0.4" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="📁" Grid.Column="2" Margin="4,0,0,0"
                                            Padding="6,4" FontSize="10"
                                            ToolTip="Open in Explorer"
                                            Command="{Binding OpenFolderCommand}"
                                            Style="{StaticResource SecondaryButton}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>
    </Border>
</UserControl>
