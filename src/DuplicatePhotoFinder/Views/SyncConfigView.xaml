<UserControl x:Class="DuplicatePhotoFinder.Views.SyncConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,40,40,40" MaxWidth="640" HorizontalAlignment="Center">

            <!-- Header -->
            <TextBlock Text="Folder Sync"
                       Style="{StaticResource HeadingText}"
                       FontSize="26" Margin="0,0,0,8" />
            <TextBlock Text="Sync files and folders between two locations."
                       Style="{StaticResource SubheadingText}"
                       Margin="0,0,0,32" />

            <!-- Source folder -->
            <TextBlock Text="Source Folder" Foreground="{StaticResource TextPrimaryBrush}"
                       FontWeight="SemiBold" Margin="0,0,0,6" />
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding Sync.SourceFolder, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Column="0" Margin="0,0,8,0" />
                <Button Content="Browse" Grid.Column="1"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding Sync.BrowseSourceCommand}" />
            </Grid>

            <!-- Destination folder -->
            <TextBlock Text="Destination Folder" Foreground="{StaticResource TextPrimaryBrush}"
                       FontWeight="SemiBold" Margin="0,0,0,6" />
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding Sync.DestFolder, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Column="0" Margin="0,0,8,0" />
                <Button Content="Browse" Grid.Column="1"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding Sync.BrowseDestCommand}" />
            </Grid>

            <!-- Sync mode -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Sync Mode" Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold" FontSize="14" Margin="0,0,0,14" />

                    <RadioButton GroupName="SyncMode" IsChecked="{Binding Sync.ModeOneWay}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="One-Way Copy" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Copy new and changed files from source to destination. Never deletes files."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="SyncMode" IsChecked="{Binding Sync.ModeMirror}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Mirror" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="One-Way Copy, plus delete files in destination that no longer exist in source."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="SyncMode" IsChecked="{Binding Sync.ModeTwoWay}">
                        <StackPanel>
                            <TextBlock Text="Two-Way" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Copy newer files in both directions. No deletions."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- Options -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,32">
                <StackPanel>
                    <TextBlock Text="Options" Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold" FontSize="14" Margin="0,0,0,14" />

                    <TextBlock Text="Compare files by:" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8" />
                    <RadioButton GroupName="Compare" IsChecked="{Binding Sync.CompareByDate}"
                                 Content="Modified date (fast)" Margin="0,0,0,6" />
                    <RadioButton GroupName="Compare" IsChecked="{Binding Sync.CompareBySizeAndDate}"
                                 Content="File size + modified date (safer)" Margin="0,0,0,16" />

                    <CheckBox Content="Preview changes before syncing (recommended)"
                              IsChecked="{Binding Sync.PreviewBeforeSync}" />
                </StackPanel>
            </Border>

            <!-- Action buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Content="Back" Grid.Column="0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding Sync.GoHomeCommand}" />
                <Button Content="Start Sync" Grid.Column="2"
                        Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource SuccessBrush}"
                        FontSize="16" Padding="24,12"
                        Command="{Binding Sync.StartSyncCommand}" />
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
